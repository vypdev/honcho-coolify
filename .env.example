# Coolify variables for the parallel Honcho Compose application.
# Enter these in Coolify's Environment Variables section.
# Do not commit real values.

HONCHO_DB_PASSWORD=REPLACE_WITH_LOCAL_RANDOM_VALUE
LLM_OPENAI_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
OPENAI_API_KEY=REPLACE_WITH_OPENAI_EMBEDDING_KEY

# Optional during parallel validation; keep the default to avoid conflicts.
HONCHO_API_PORT=18081
AUTH_USE_AUTH=false
