# Safe local reference for Coolify's generated and user-provided variables.
# Coolify generates SERVICE_PASSWORD_64_HONCHO_DB automatically.
# The Compose file maps that generated value to HONCHO_DB_PASSWORD.

SERVICE_PASSWORD_64_HONCHO_DB=REPLACE_WITH_LOCAL_RANDOM_VALUE
LLM_OPENAI_API_KEY=
OPENAI_API_KEY=

# Optional validation settings.
HONCHO_API_PORT=18081
AUTH_USE_AUTH=false
